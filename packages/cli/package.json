{
  "name": "@agentlens/cli",
  "version": "0.1.0",
  "description": "AgentLens CLI - Universal wrapper for tracing CLI agents",
  "bin": {
    "agent-trace": "./dist/bin.js",
    "agentlens": "./dist/bin.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts src/bin.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts src/bin.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@agentlens/sdk": "workspace:*",
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "strip-ansi": "^7.1.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "vitest": "^1.6.0",
    "@types/node": "^20.0.0"
  }
}
